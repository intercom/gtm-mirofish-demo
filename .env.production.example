# ═══════════════════════════════════════════════════════
# GTM MiroFish Demo — Production Environment
# ═══════════════════════════════════════════════════════
# Copy to .env.production and fill in values.
# Usage: docker compose -f docker-compose.yml -f docker-compose.prod.yml --profile production up -d

# LLM Provider
LLM_PROVIDER=anthropic
LLM_API_KEY=

# Zep Cloud
ZEP_API_KEY=

# Auth (recommended for production)
AUTH_ENABLED=true
AUTH_PROVIDER=google
AUTH_ALLOWED_DOMAIN=intercom.io
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Server
FLASK_DEBUG=false
SECRET_KEY=generate-a-strong-random-value

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=https://yourdomain.com

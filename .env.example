# ═══════════════════════════════════════════════════════
# GTM MiroFish Demo — Environment Configuration
# ═══════════════════════════════════════════════════════

# LLM Provider Configuration
# Supported: anthropic, openai, gemini
# Setting LLM_PROVIDER auto-configures BASE_URL and MODEL_NAME
# You can override BASE_URL and MODEL_NAME explicitly if needed
LLM_PROVIDER=anthropic
LLM_API_KEY=your-api-key-here

# Optional: Override auto-configured values
# LLM_BASE_URL=https://api.anthropic.com/v1/
# LLM_MODEL_NAME=claude-sonnet-4-20250514

# Zep Cloud — Knowledge Graph Memory
# Sign up at https://app.getzep.com/ (free tier sufficient for PoC)
ZEP_API_KEY=your-zep-api-key-here

# ═══════════════════════════════════════════════════════
# Auth (Optional — enable for production/Railway deployment)
# ═══════════════════════════════════════════════════════
AUTH_ENABLED=false
AUTH_PROVIDER=google
AUTH_ALLOWED_DOMAIN=intercom.io
FRONTEND_URL=http://localhost:3000
# OAUTH_REDIRECT_URI=  # Auto-detected; override for proxied deployments

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Okta SSO (alternative to Google — set AUTH_PROVIDER=okta)
# OKTA_ISSUER=https://your-org.okta.com/oauth2/default
# OKTA_CLIENT_ID=
# OKTA_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════
# Accelerated LLM (Optional — for parallel processing)
# ═══════════════════════════════════════════════════════
# LLM_BOOST_API_KEY=
# LLM_BOOST_BASE_URL=
# LLM_BOOST_MODEL_NAME=

# ═══════════════════════════════════════════════════════
# OASIS Simulation (camel-ai/oasis)
# ═══════════════════════════════════════════════════════
OASIS_DEFAULT_MAX_ROUNDS=10

# ═══════════════════════════════════════════════════════
# Server Configuration
# ═══════════════════════════════════════════════════════
# FLASK_ENV selects config class: development (default) | production | testing
# FLASK_ENV=development
BACKEND_PORT=5001
FRONTEND_PORT=3000
FLASK_DEBUG=true
SECRET_KEY=change-me-in-production

# CORS — comma-separated allowed origins (default '*' allows all)
# Example: https://frontend-production-86ea.up.railway.app,http://localhost:3000
CORS_ORIGINS=*

# Logging — file path and level (DEBUG, INFO, WARNING, ERROR)
# LOG_FILE=
# LOG_LEVEL=INFO

# Demo speed multiplier (1.0 = normal, 2.0 = double speed)
# DEMO_SPEED=1.0

# Demo preset — load curated simulation/report/dashboard fixtures for presentations
# DEMO_PRESET=true
